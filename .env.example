# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Admin
ADMIN_PASSWORD=change-this-password

# Telegram backups (see README for setup steps)
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
# Any random long string — Vercel Cron sends it back as
# "Authorization: Bearer <CRON_SECRET>" so /api/cron/telegram-backup can
# verify the request actually came from Vercel's scheduler.
CRON_SECRET=change-this-to-a-random-string

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
